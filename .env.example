# Required for dynamic VAOM narration and scenario generation.
# Without this, the game falls back to pre-built content (still fully playable).
ANTHROPIC_API_KEY=

# Optional — enables spoken VAOM narration via Azure Speech (MAI-Voice-1).
# Leave blank to run text-only (the baseline experience).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=swedencentral
AZURE_SPEECH_VOICE=
